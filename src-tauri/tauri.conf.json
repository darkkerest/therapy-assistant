{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Therapy Assistant",
  "version": "0.1.2",
  "identifier": "com.therapy-assistant.app",
  "build": {
    "beforeDevCommand": "npm run build:helper && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:helper && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Therapy Assistant",
        "width": 360,
        "height": 220,
        "minWidth": 320,
        "minHeight": 180,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true,
        "alwaysOnTop": true,
        "center": false,
        "x": 20,
        "y": 40
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/*"],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist"
    }
  }
}
